import { useState } from "react";

const ENV_OPTIONS = ["ROTATIONAL", "TRENDING", "CHOP", "EXPANSION", "UNKNOWN"];
const GRADE_OPTIONS = ["A", "B", "C", "F"];
const SETUP_TAGS = ["BREAKOUT", "PULLBACK", "REVERSAL", "CONTINUATION", "OPENING RANGE", "FAILED AUCTION", "ANTICIPATION", "FOMO", "CHASE", "OTHER"];
const LOSS_TAGS = ["EARLY", "CHOP", "REVERSAL", "CHASE", "OVERSIZED", "FOMO", "LOW VOLUME", "COUNTERTREND", "OPENING RANGE NOISE", "EXPANSION"];

const emptyTrade = () => ({
  id: Date.now(),
  direction: "",
  time: "",
  entry: "",
  exit: "",
  result: "",
  grade: "",
  immediateFollowThrough: null,
  negotiable: null,
  mae: "",
  mfe: "",
  why: "",
  wouldTakeAgain: null,
  marketDid: null,
  lossTag: "",
  setupTag: "",
  doNothingOutcome: "",
  notes: "",
});

const emptySession = () => ({
  date: new Date().toISOString().slice(0, 10),
  environment: "",
  environmentCorrect: null,
  firstTradeSetup: null,
  cheatScore: "",
  patienceScore: "",
  walkAways: "",
  reentryCount: "",
  sessionNotes: "",
  trades: [emptyTrade()],
});

function Chip({ label, active, onClick, color = "blue" }) {
  const colors = {
    blue: active ? "bg-blue-900 text-blue-100 border-blue-500" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    red: active ? "bg-red-900 text-red-100 border-red-500" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    green: active ? "bg-emerald-900 text-emerald-100 border-emerald-500" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    yellow: active ? "bg-yellow-900 text-yellow-100 border-yellow-500" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    purple: active ? "bg-purple-900 text-purple-100 border-purple-500" : "bg-zinc-900 text-zinc-400 border-zinc-700",
  };
  return (
    <button
      onClick={onClick}
      className={`px-3 py-1 text-xs font-mono border rounded cursor-pointer transition-all ${colors[color]}`}
    >
      {label}
    </button>
  );
}

function YesNo({ value, onChange, yesLabel = "YES", noLabel = "NO" }) {
  return (
    <div className="flex gap-2">
      <Chip label={yesLabel} active={value === true} onClick={() => onChange(value === true ? null : true)} color="green" />
      <Chip label={noLabel} active={value === false} onClick={() => onChange(value === false ? null : false)} color="red" />
    </div>
  );
}

function Field({ label, hint, children }) {
  return (
    <div className="mb-4">
      <div className="text-xs font-mono text-zinc-400 uppercase tracking-widest mb-1">{label}</div>
      {hint && <div className="text-xs text-zinc-600 mb-2 italic">{hint}</div>}
      {children}
    </div>
  );
}

function Input({ value, onChange, placeholder, type = "text", small }) {
  return (
    <input
      type={type}
      value={value}
      onChange={e => onChange(e.target.value)}
      placeholder={placeholder}
      className={`bg-zinc-900 border border-zinc-700 text-zinc-100 rounded px-3 py-2 font-mono text-sm w-full focus:outline-none focus:border-zinc-400 placeholder-zinc-700 ${small ? "text-xs py-1" : ""}`}
    />
  );
}

function TextArea({ value, onChange, placeholder, rows = 2 }) {
  return (
    <textarea
      value={value}
      onChange={e => onChange(e.target.value)}
      placeholder={placeholder}
      rows={rows}
      className="bg-zinc-900 border border-zinc-700 text-zinc-100 rounded px-3 py-2 font-mono text-sm w-full focus:outline-none focus:border-zinc-400 placeholder-zinc-700 resize-none"
    />
  );
}

function GradeButton({ grade, active, onClick }) {
  const colors = {
    A: active ? "bg-emerald-800 text-emerald-100 border-emerald-400" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    B: active ? "bg-blue-800 text-blue-100 border-blue-400" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    C: active ? "bg-yellow-800 text-yellow-100 border-yellow-400" : "bg-zinc-900 text-zinc-400 border-zinc-700",
    F: active ? "bg-red-800 text-red-100 border-red-400" : "bg-zinc-900 text-zinc-400 border-zinc-700",
  };
  const desc = { A: "Take again tomorrow", B: "Good, minor flaw", C: "Questionable", F: "Never should happen" };
  return (
    <button
      onClick={onClick}
      className={`px-4 py-2 border rounded font-mono text-sm transition-all cursor-pointer ${colors[grade]}`}
      title={desc[grade]}
    >
      {grade}
    </button>
  );
}

function TradeCard({ trade, index, onChange, onRemove }) {
  const update = (key, val) => onChange({ ...trade, [key]: val });
  const resultNum = parseFloat(trade.result);
  const resultColor = isNaN(resultNum) ? "text-zinc-400" : resultNum >= 0 ? "text-emerald-400" : "text-red-400";

  return (
    <div className="border border-zinc-700 rounded-lg p-5 mb-4 bg-zinc-950">
      {/* Header */}
      <div className="flex items-center justify-between mb-4">
        <div className="flex items-center gap-3">
          <span className="text-zinc-500 font-mono text-sm">TRADE</span>
          <span className="text-white font-mono text-xl font-bold">#{index + 1}</span>
          {trade.result !== "" && (
            <span className={`font-mono text-lg font-bold ${resultColor}`}>
              {resultNum >= 0 ? "+" : ""}{trade.result}
            </span>
          )}
        </div>
        <button onClick={onRemove} className="text-zinc-700 hover:text-zinc-400 font-mono text-xs cursor-pointer">REMOVE</button>
      </div>

      {/* Row 1: Time, Direction, Entry, Exit */}
      <div className="grid grid-cols-4 gap-3 mb-4">
        <Field label="Time">
          <Input value={trade.time} onChange={v => update("time", v)} placeholder="8:32" />
        </Field>
        <Field label="Direction">
          <div className="flex gap-2 mt-1">
            <Chip label="LONG" active={trade.direction === "LONG"} onClick={() => update("direction", trade.direction === "LONG" ? "" : "LONG")} color="green" />
            <Chip label="SHORT" active={trade.direction === "SHORT"} onClick={() => update("direction", trade.direction === "SHORT" ? "" : "SHORT")} color="red" />
          </div>
        </Field>
        <Field label="Entry">
          <Input value={trade.entry} onChange={v => update("entry", v)} placeholder="21,450" />
        </Field>
        <Field label="Exit">
          <Input value={trade.exit} onChange={v => update("exit", v)} placeholder="21,460" />
        </Field>
      </div>

      {/* Result + MAE + MFE */}
      <div className="grid grid-cols-3 gap-3 mb-4">
        <Field label="Result ($)" hint="Actual P&L in dollars">
          <Input value={trade.result} onChange={v => update("result", v)} placeholder="+50" />
        </Field>
        <Field label="MAE (pts)" hint="How far against you before resolution — TIER 1">
          <Input value={trade.mae} onChange={v => update("mae", v)} placeholder="8" />
        </Field>
        <Field label="MFE (pts)" hint="How far in your favor before exit">
          <Input value={trade.mfe} onChange={v => update("mfe", v)} placeholder="12" />
        </Field>
      </div>

      {/* Immediate Follow Through + Negotiable */}
      <div className="grid grid-cols-2 gap-6 mb-4">
        <Field label="Immediate Follow Through?" hint="Did price move your way almost immediately?">
          <YesNo value={trade.immediateFollowThrough} onChange={v => update("immediateFollowThrough", v)} />
        </Field>
        <Field label="Market Negotiable?" hint="Did you have time to manage discretion, or did it move too fast?">
          <YesNo value={trade.negotiable} onChange={v => update("negotiable", v)} />
        </Field>
      </div>

      {/* Why + What would've proven wrong */}
      <Field label="Why Did I Take It?" hint="One sentence only. e.g. 'Failed auction at prior high' or 'Breakout above opening range'">
        <TextArea value={trade.why} onChange={v => update("why", v)} placeholder="One sentence." rows={1} />
      </Field>

      {/* Setup Tag */}
      <Field label="Setup Tag">
        <div className="flex flex-wrap gap-2">
          {SETUP_TAGS.map(t => (
            <Chip key={t} label={t} active={trade.setupTag === t} onClick={() => update("setupTag", trade.setupTag === t ? "" : t)} color="blue" />
          ))}
        </div>
      </Field>

      {/* Loss Tag (only if red) */}
      {!isNaN(resultNum) && resultNum < 0 && (
        <Field label="Loss Category" hint="Tag every losing trade">
          <div className="flex flex-wrap gap-2">
            {LOSS_TAGS.map(t => (
              <Chip key={t} label={t} active={trade.lossTag === t} onClick={() => update("lossTag", trade.lossTag === t ? "" : t)} color="red" />
            ))}
          </div>
        </Field>
      )}

      {/* Did market do what I expected + Would take again */}
      <div className="grid grid-cols-2 gap-6 mb-4">
        <Field label="Did Market Do What I Expected?">
          <YesNo value={trade.marketDid} onChange={v => update("marketDid", v)} />
        </Field>
        <Field label="Would Take Again?">
          <div className="flex gap-2">
            <Chip label="YES" active={trade.wouldTakeAgain === "yes"} onClick={() => update("wouldTakeAgain", trade.wouldTakeAgain === "yes" ? null : "yes")} color="green" />
            <Chip label="MAYBE" active={trade.wouldTakeAgain === "maybe"} onClick={() => update("wouldTakeAgain", trade.wouldTakeAgain === "maybe" ? null : "maybe")} color="yellow" />
            <Chip label="NO" active={trade.wouldTakeAgain === "no"} onClick={() => update("wouldTakeAgain", trade.wouldTakeAgain === "no" ? null : "no")} color="red" />
          </div>
        </Field>
      </div>

      {/* Grade */}
      <Field label="Trade Grade" hint="Grade the TRADE, not the result. A losing trade can be an A.">
        <div className="flex gap-3">
          {GRADE_OPTIONS.map(g => (
            <GradeButton key={g} grade={g} active={trade.grade === g} onClick={() => update("grade", trade.grade === g ? "" : g)} />
          ))}
        </div>
      </Field>

      {/* What would've happened if I did nothing */}
      <Field label="What Would've Happened If I Did Nothing?" hint="Forces comparison vs. the monster move: no trade.">
        <TextArea value={trade.doNothingOutcome} onChange={v => update("doNothingOutcome", v)} placeholder="e.g. 'Better entry appeared 4 min later' / 'Saved $80' / 'Missed winner'" rows={1} />
      </Field>

      {/* Notes */}
      <Field label="Notes / Lesson">
        <TextArea value={trade.notes} onChange={v => update("notes", v)} placeholder="One sentence lesson." rows={1} />
      </Field>
    </div>
  );
}

function SummaryPanel({ session }) {
  const trades = session.trades;
  const withResult = trades.filter(t => t.result !== "" && !isNaN(parseFloat(t.result)));
  const totalPnL = withResult.reduce((s, t) => s + parseFloat(t.result), 0);
  const winners = withResult.filter(t => parseFloat(t.result) >= 0);
  const losers = withResult.filter(t => parseFloat(t.result) < 0);
  const winRate = withResult.length > 0 ? Math.round((winners.length / withResult.length) * 100) : null;
  const avgMAE = trades.filter(t => t.mae !== "").length > 0
    ? (trades.filter(t => t.mae !== "").reduce((s, t) => s + parseFloat(t.mae || 0), 0) / trades.filter(t => t.mae !== "").length).toFixed(1)
    : null;
  const winMAE = winners.filter(t => t.mae !== "").length > 0
    ? (winners.filter(t => t.mae !== "").reduce((s, t) => s + parseFloat(t.mae || 0), 0) / winners.filter(t => t.mae !== "").length).toFixed(1)
    : null;
  const lossMAE = losers.filter(t => t.mae !== "").length > 0
    ? (losers.filter(t => t.mae !== "").reduce((s, t) => s + parseFloat(t.mae || 0), 0) / losers.filter(t => t.mae !== "").length).toFixed(1)
    : null;

  const iftYes = trades.filter(t => t.immediateFollowThrough === true).length;
  const iftNo = trades.filter(t => t.immediateFollowThrough === false).length;
  const negYes = trades.filter(t => t.negotiable === true).length;
  const negNo = trades.filter(t => t.negotiable === false).length;

  const gradeCounts = { A: 0, B: 0, C: 0, F: 0 };
  trades.forEach(t => { if (t.grade) gradeCounts[t.grade]++; });

  const lossTags = {};
  losers.forEach(t => { if (t.lossTag) lossTags[t.lossTag] = (lossTags[t.lossTag] || 0) + 1; });

  const fiveQ = [
    { q: "Did I follow rules?", key: "followedRules" },
    { q: "Did I protect both accounts?", key: "protectedAccounts" },
    { q: "Did I record everything?", key: "recorded" },
    { q: "Did I review?", key: "reviewed" },
    { q: "Did I survive?", key: "survived" },
  ];
  const [checklist, setChecklist] = useState({ followedRules: null, protectedAccounts: null, recorded: null, reviewed: null, survived: null });

  return (
    <div className="border border-zinc-700 rounded-lg p-5 bg-zinc-950 mb-6">
      <div className="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-4">Session Summary</div>

      {/* P&L Row */}
      <div className="grid grid-cols-4 gap-4 mb-4">
        <div className="bg-zinc-900 rounded p-3 text-center">
          <div className="text-xs text-zinc-500 font-mono mb-1">NET P&L</div>
          <div className={`text-2xl font-mono font-bold ${totalPnL >= 0 ? "text-emerald-400" : "text-red-400"}`}>
            {totalPnL >= 0 ? "+" : ""}{totalPnL.toFixed(0)}
          </div>
        </div>
        <div className="bg-zinc-900 rounded p-3 text-center">
          <div className="text-xs text-zinc-500 font-mono mb-1">WIN RATE</div>
          <div className="text-2xl font-mono font-bold text-zinc-100">{winRate !== null ? `${winRate}%` : "—"}</div>
        </div>
        <div className="bg-zinc-900 rounded p-3 text-center">
          <div className="text-xs text-zinc-500 font-mono mb-1">AVG MAE (W)</div>
          <div className="text-2xl font-mono font-bold text-emerald-400">{winMAE !== null ? winMAE : "—"}</div>
        </div>
        <div className="bg-zinc-900 rounded p-3 text-center">
          <div className="text-xs text-zinc-500 font-mono mb-1">AVG MAE (L)</div>
          <div className="text-2xl font-mono font-bold text-red-400">{lossMAE !== null ? lossMAE : "—"}</div>
        </div>
      </div>

      {/* Grades + Tags */}
      <div className="grid grid-cols-2 gap-4 mb-4">
        <div className="bg-zinc-900 rounded p-3">
          <div className="text-xs text-zinc-500 font-mono mb-2">TRADE GRADES</div>
          <div className="flex gap-3">
            {["A","B","C","F"].map(g => (
              <div key={g} className="text-center">
                <div className={`text-xl font-mono font-bold ${g === "A" ? "text-emerald-400" : g === "B" ? "text-blue-400" : g === "C" ? "text-yellow-400" : "text-red-400"}`}>{gradeCounts[g]}</div>
                <div className="text-xs text-zinc-500 font-mono">{g}</div>
              </div>
            ))}
          </div>
        </div>
        <div className="bg-zinc-900 rounded p-3">
          <div className="text-xs text-zinc-500 font-mono mb-2">FOLLOW THROUGH / NEGOTIABLE</div>
          <div className="flex gap-4 text-xs font-mono">
            <div><span className="text-emerald-400">{iftYes}</span> IFT Yes / <span className="text-red-400">{iftNo}</span> No</div>
            <div><span className="text-emerald-400">{negYes}</span> Neg Yes / <span className="text-red-400">{negNo}</span> No</div>
          </div>
        </div>
      </div>

      {/* Loss tag breakdown */}
      {Object.keys(lossTags).length > 0 && (
        <div className="bg-zinc-900 rounded p-3 mb-4">
          <div className="text-xs text-zinc-500 font-mono mb-2">LOSS BREAKDOWN</div>
          <div className="flex flex-wrap gap-3">
            {Object.entries(lossTags).sort((a, b) => b[1] - a[1]).map(([tag, count]) => (
              <div key={tag} className="flex items-center gap-1">
                <span className="text-red-400 font-mono font-bold text-sm">{count}</span>
                <span className="text-zinc-400 font-mono text-xs">{tag}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* End of session checklist */}
      <div className="bg-zinc-900 rounded p-3">
        <div className="text-xs text-zinc-500 font-mono mb-3">POST-SESSION CHECKLIST</div>
        <div className="space-y-2">
          {fiveQ.map(({ q, key }) => (
            <div key={key} className="flex items-center justify-between">
              <span className="text-zinc-300 font-mono text-xs">{q}</span>
              <YesNo value={checklist[key]} onChange={v => setChecklist(prev => ({ ...prev, [key]: v }))} />
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

function TradesAvoided({ avoided, setAvoided }) {
  const addAvoided = () => setAvoided(prev => [...prev, { id: Date.now(), setup: "", passed: null, outcome: "" }]);
  const update = (id, key, val) => setAvoided(prev => prev.map(a => a.id === id ? { ...a, [key]: val } : a));
  const remove = (id) => setAvoided(prev => prev.filter(a => a.id !== id));

  return (
    <div className="border border-zinc-700 rounded-lg p-5 mb-6 bg-zinc-950">
      <div className="flex items-center justify-between mb-4">
        <div>
          <div className="text-xs font-mono text-zinc-500 uppercase tracking-widest">Trades Avoided</div>
          <div className="text-xs text-zinc-600 italic mt-1">Every correctly avoided garbage setup = +1 point. This is a skill.</div>
        </div>
        <button onClick={addAvoided} className="text-xs font-mono text-zinc-400 border border-zinc-700 px-3 py-1 rounded hover:border-zinc-500 cursor-pointer">+ ADD</button>
      </div>
      {avoided.length === 0 && <div className="text-zinc-700 font-mono text-xs text-center py-4">No avoided setups logged yet.</div>}
      {avoided.map((a, i) => (
        <div key={a.id} className="border border-zinc-800 rounded p-3 mb-2 grid grid-cols-3 gap-3 items-end">
          <div>
            <div className="text-xs text-zinc-500 font-mono mb-1">Setup Seen</div>
            <Input value={a.setup} onChange={v => update(a.id, "setup", v)} placeholder="Chop reversal" small />
          </div>
          <div>
            <div className="text-xs text-zinc-500 font-mono mb-1">Passed?</div>
            <YesNo value={a.passed} onChange={v => update(a.id, "passed", v)} />
          </div>
          <div>
            <div className="text-xs text-zinc-500 font-mono mb-1">Outcome (if traded)</div>
            <Input value={a.outcome} onChange={v => update(a.id, "outcome", v)} placeholder="Would've lost" small />
          </div>
        </div>
      ))}
      {avoided.length > 0 && (
        <div className="mt-2 text-right">
          <span className="font-mono text-emerald-400 text-sm font-bold">{avoided.filter(a => a.passed === true).length}</span>
          <span className="font-mono text-zinc-500 text-xs"> setups correctly avoided</span>
        </div>
      )}
    </div>
  );
}

export default function KaizenTradeTemplate() {
  const [session, setSession] = useState(emptySession());
  const [avoided, setAvoided] = useState([]);
  const [view, setView] = useState("session"); // session | summary

  const updateSession = (key, val) => setSession(prev => ({ ...prev, [key]: val }));

  const addTrade = () => setSession(prev => ({ ...prev, trades: [...prev.trades, emptyTrade()] }));
  const updateTrade = (id, updated) => setSession(prev => ({ ...prev, trades: prev.trades.map(t => t.id === id ? updated : t) }));
  const removeTrade = (id) => setSession(prev => ({ ...prev, trades: prev.trades.filter(t => t.id !== id) }));

  const resetSession = () => {
    if (window.confirm("Start a new session? Current data will be cleared.")) {
      setSession(emptySession());
      setAvoided([]);
      setView("session");
    }
  };

  return (
    <div style={{ background: "#0a0a0a", minHeight: "100vh", fontFamily: "'JetBrains Mono', 'Courier New', monospace" }}>
      {/* Header */}
      <div style={{ borderBottom: "1px solid #27272a", padding: "16px 24px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div>
          <div style={{ color: "#71717a", fontSize: "10px", letterSpacing: "0.2em", marginBottom: "2px" }}>KAIZEN TRADE AUTOPSY</div>
          <div style={{ color: "#e4e4e7", fontSize: "18px", fontWeight: "700", letterSpacing: "0.05em" }}>SESSION LOG</div>
        </div>
        <div style={{ display: "flex", gap: "8px" }}>
          <button
            onClick={() => setView(view === "session" ? "summary" : "session")}
            style={{ background: "none", border: "1px solid #3f3f46", color: "#a1a1aa", padding: "6px 14px", borderRadius: "4px", fontSize: "11px", cursor: "pointer", fontFamily: "inherit" }}
          >
            {view === "session" ? "VIEW SUMMARY" : "VIEW SESSION"}
          </button>
          <button
            onClick={resetSession}
            style={{ background: "none", border: "1px solid #3f3f46", color: "#71717a", padding: "6px 14px", borderRadius: "4px", fontSize: "11px", cursor: "pointer", fontFamily: "inherit" }}
          >
            NEW SESSION
          </button>
        </div>
      </div>

      <div style={{ maxWidth: "860px", margin: "0 auto", padding: "24px 16px" }}>

        {/* Mantra */}
        <div style={{ borderLeft: "2px solid #3f3f46", paddingLeft: "16px", marginBottom: "28px" }}>
          <div style={{ color: "#52525b", fontSize: "11px", fontStyle: "italic", lineHeight: "1.8" }}>
            I protect the account. I stack clean days. I become impossible to kill.<br />
            Has the market earned my participation?
          </div>
        </div>

        {/* PRE-SESSION */}
        <div style={{ border: "1px solid #3f3f46", borderRadius: "8px", padding: "20px", marginBottom: "20px", background: "#09090b" }}>
          <div style={{ color: "#71717a", fontSize: "10px", letterSpacing: "0.2em", marginBottom: "16px" }}>PRE-SESSION</div>

          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "16px" }}>
            <div>
              <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "6px" }}>DATE</div>
              <input
                type="date"
                value={session.date}
                onChange={e => updateSession("date", e.target.value)}
                style={{ background: "#18181b", border: "1px solid #3f3f46", color: "#e4e4e7", borderRadius: "4px", padding: "8px 12px", fontFamily: "inherit", fontSize: "13px", width: "100%" }}
              />
            </div>
            <div>
              <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "6px" }}>FIRST TRADE FOLLOWED SETUP?</div>
              <div style={{ display: "flex", gap: "8px", marginTop: "8px" }}>
                {[true, false].map(v => (
                  <button key={String(v)} onClick={() => updateSession("firstTradeSetup", session.firstTradeSetup === v ? null : v)}
                    style={{ padding: "6px 16px", border: `1px solid ${session.firstTradeSetup === v ? (v ? "#10b981" : "#ef4444") : "#3f3f46"}`, borderRadius: "4px", background: session.firstTradeSetup === v ? (v ? "#064e3b" : "#450a0a") : "#18181b", color: session.firstTradeSetup === v ? (v ? "#6ee7b7" : "#fca5a5") : "#71717a", fontSize: "11px", cursor: "pointer", fontFamily: "inherit" }}>
                    {v ? "YES" : "NO"}
