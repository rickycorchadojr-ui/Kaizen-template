          {/* Market Environment */}
          <div style={{ marginBottom: "12px" }}>
            <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "6px" }}>MARKET ENVIRONMENT — Classify before first trade</div>
            <div style={{ display: "flex", flexWrap: "wrap", gap: "8px" }}>
              {ENV_OPTIONS.map(e => (
                <button key={e} onClick={() => updateSession("environment", session.environment === e ? "" : e)}
                  style={{ padding: "6px 14px", border: `1px solid ${session.environment === e ? "#6366f1" : "#3f3f46"}`, borderRadius: "4px", background: session.environment === e ? "#1e1b4b" : "#18181b", color: session.environment === e ? "#a5b4fc" : "#71717a", fontSize: "11px", cursor: "pointer", fontFamily: "inherit" }}>
                  {e}
                </button>
              ))}
            </div>
            <div style={{ color: "#52525b", fontSize: "10px", marginTop: "6px", fontStyle: "italic" }}>
              ROTATIONAL = levels respected, discretion works · CHOP = whipsaws, avoid · EXPANSION = violent, fast, kills discretion
            </div>
          </div>
        </div>

        {view === "summary" ? (
          <SummaryPanel session={session} />
        ) : (
          <>
            {/* Trades */}
            <div style={{ marginBottom: "8px", color: "#71717a", fontSize: "10px", letterSpacing: "0.2em" }}>TRADE LOG</div>
            {session.trades.map((trade, i) => (
              <TradeCard
                key={trade.id}
                trade={trade}
                index={i}
                onChange={updated => updateTrade(trade.id, updated)}
                onRemove={() => removeTrade(trade.id)}
              />
            ))}
            <button
              onClick={addTrade}
              style={{ width: "100%", background: "none", border: "1px dashed #3f3f46", color: "#52525b", padding: "12px", borderRadius: "8px", fontSize: "11px", cursor: "pointer", fontFamily: "inherit", marginBottom: "20px" }}
            >
              + ADD TRADE
            </button>

            {/* Trades Avoided */}
            <TradesAvoided avoided={avoided} setAvoided={setAvoided} />

            {/* Session metrics */}
            <div style={{ border: "1px solid #3f3f46", borderRadius: "8px", padding: "20px", marginBottom: "20px", background: "#09090b" }}>
              <div style={{ color: "#71717a", fontSize: "10px", letterSpacing: "0.2em", marginBottom: "16px" }}>SESSION METRICS</div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: "12px", marginBottom: "16px" }}>
                {[
                  { key: "reentryCount", label: "Re-entry Count", hint: "Avg seconds between trades" },
                  { key: "walkAways", label: "Conscious Walk-Aways", hint: "Times passed on a setup" },
                  { key: "patienceScore", label: "Patience Score (1–5)", hint: "1=clicked fast, 5=fully let market prove" },
                ].map(({ key, label, hint }) => (
                  <div key={key}>
                    <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "2px" }}>{label}</div>
                    <div style={{ color: "#52525b", fontSize: "9px", marginBottom: "6px", fontStyle: "italic" }}>{hint}</div>
                    <input
                      value={session[key]}
                      onChange={e => updateSession(key, e.target.value)}
                      style={{ background: "#18181b", border: "1px solid #3f3f46", color: "#e4e4e7", borderRadius: "4px", padding: "8px 12px", fontFamily: "inherit", fontSize: "13px", width: "100%" }}
                    />
                  </div>
                ))}
              </div>

              {/* Environment correct after session */}
              <div style={{ marginBottom: "12px" }}>
                <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "6px" }}>WAS ENVIRONMENT CALL CORRECT?</div>
                <div style={{ display: "flex", gap: "8px" }}>
                  {[true, false, "unknown"].map(v => (
                    <button key={String(v)} onClick={() => updateSession("environmentCorrect", session.environmentCorrect === v ? null : v)}
                      style={{ padding: "6px 16px", border: `1px solid ${session.environmentCorrect === v ? (v === true ? "#10b981" : v === false ? "#ef4444" : "#6366f1") : "#3f3f46"}`, borderRadius: "4px", background: session.environmentCorrect === v ? (v === true ? "#064e3b" : v === false ? "#450a0a" : "#1e1b4b") : "#18181b", color: session.environmentCorrect === v ? (v === true ? "#6ee7b7" : v === false ? "#fca5a5" : "#a5b4fc") : "#71717a", fontSize: "11px", cursor: "pointer", fontFamily: "inherit" }}>
                      {v === true ? "YES" : v === false ? "NO" : "UNKNOWN"}
                    </button>
                  ))}
                </div>
              </div>

              {/* Session notes */}
              <div>
                <div style={{ color: "#71717a", fontSize: "10px", marginBottom: "6px" }}>SESSION NOTES / LESSON</div>
                <textarea
                  value={session.sessionNotes}
                  onChange={e => updateSession("sessionNotes", e.target.value)}
                  rows={3}
                  placeholder="What did the session teach you? One key takeaway."
                  style={{ background: "#18181b", border: "1px solid #3f3f46", color: "#e4e4e7", borderRadius: "4px", padding: "8px 12px", fontFamily: "inherit", fontSize: "12px", width: "100%", resize: "none" }}
                />
              </div>
            </div>

            {/* Post-session checklist */}
            <div style={{ border: "1px solid #3f3f46", borderRadius: "8px", padding: "20px", background: "#09090b" }}>
              <div style={{ color: "#71717a", fontSize: "10px", letterSpacing: "0.2em", marginBottom: "12px" }}>POST-SESSION — DAILY CHECK</div>
              <SummaryPanel session={session} />
            </div>
          </>
        )}

        {/* Footer reminder */}
        <div style={{ marginTop: "24px", color: "#3f3f46", fontSize: "10px", textAlign: "center", fontStyle: "italic" }}>
          The account staying open is the win condition. Profit is the bonus.
        </div>
      </div>
    </div>
  );
}
